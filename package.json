{
  "name": "figma-mcp-write",
  "version": "0.1.0",
  "description": "Full read/write Figma MCP server for Claude Code. 58 tools that make AI a UX/UI developer.",
  "license": "MIT",
  "author": "Hassan",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropics/figma-mcp-write"
  },
  "keywords": [
    "figma",
    "mcp",
    "claude",
    "ai",
    "design",
    "ux",
    "ui",
    "model-context-protocol"
  ],
  "type": "module",
  "bin": {
    "figma-mcp-write": "./dist/server/index.js"
  },
  "main": "./dist/server/index.js",
  "files": [
    "dist/",
    "plugin/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "build": "npm run build:server && npm run build:plugin",
    "build:server": "tsc -p tsconfig.json",
    "build:plugin": "node scripts/build-plugin.js",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ plugin/ shared/",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.plugin.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "ws": "^8.18.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "@types/uuid": "^10.0.0",
    "@figma/plugin-typings": "^1.100.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "eslint": "^9.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
