{
  "name": "figma-mcp-write",
  "version": "0.3.0",
  "description": "Full read/write Figma MCP server for Claude Code. 68 tools through 13 MCP endpoints. Design system intelligence, compound operations, AI-only superpowers. No API token required.",
  "license": "MIT",
  "author": "Hassan",
  "repository": {
    "type": "git",
    "url": "https://github.com/aqibhassan/figma-mcp-write.git"
  },
  "homepage": "https://github.com/aqibhassan/figma-mcp-write#readme",
  "bugs": {
    "url": "https://github.com/aqibhassan/figma-mcp-write/issues"
  },
  "keywords": [
    "figma",
    "mcp",
    "model-context-protocol",
    "claude",
    "ai",
    "design",
    "ux",
    "ui",
    "figma-plugin",
    "design-system",
    "accessibility",
    "design-tokens",
    "claude-code"
  ],
  "type": "module",
  "bin": {
    "figma-mcp-write": "./dist/src/server/index.js"
  },
  "main": "./dist/src/server/index.js",
  "files": [
    "dist/",
    "plugin/manifest.json",
    "plugin/code.js",
    "plugin/ui.html",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "build": "npm run build:server && npm run build:plugin",
    "build:server": "tsc -p tsconfig.json",
    "build:plugin": "node scripts/build-plugin.js",
    "start": "node dist/src/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "lint": "eslint src/ plugin/ shared/",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.plugin.json --noEmit",
    "create-tool": "tsx scripts/create-tool.ts",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "uuid": "^11.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.100.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
